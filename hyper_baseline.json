{
    "augment.max": 3,
    "augment.methods": "elastic,rotate,flip.lr,flip.ud",
    "augment.min": 2,
    "augment.pct": 0.8,
    "batch.size": 2,
    "cnn": "unet.pp.slim",
    "dataset.cross.valid": true,
    "dropout": 0.3,
    "early.stop": 30,
    "epoch": 500,
    "keep.best.cnn.num": 5,
    "loss.asym": true,
    "loss.delta": 0.5,
    "loss.gamma": 0.3,
    "loss.weight": 0.5,
    "lr": 0.0002,
    "lr.decay.factor": 0.5,
    "lr.decay.patience": 5,
    "lr.min": 1e-05
}