{
    "augment.max": 3,
    "augment.methods": "elastic,rotate,flip.lr,flip.ud",
    "augment.min": 2,
    "augment.pct": 0.8,
    "batch.size": 1,
    "cnn": "unet.slim",
    "dataset.ver": "mda",
    "dropout": 0.3,
    "early.stop.epochs": 30,
    "epochs": 500,
    "fold": 1,
    "keep.best.cnn.num": 5,
    "loss.asym": true,
    "loss.delta": 0.5,
    "loss.gamma": 0.5,
    "loss.weight": 0.5,
    "lr": 0.0001,
    "lr.decay.factor": 0.5,
    "lr.decay.patience": 10,
    "lr.min": 1e-05,
    "no.pt": true
}