{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: KasmVNC 调试模式",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "DISPLAY": ":1",
                "QT_X11_NO_MITSHM": "1"
            }
        }
    ]
}