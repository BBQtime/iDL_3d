{
    "augment.low.limit": 2,
    "augment.methods": "elastic,rotate,flip.lr,flip.ud",
    "augment.times": 4,
    "augment.up.limit": 3,
    "batch.size": 2,
    "dropout": 0.3,
    "iter": [
        10,
        20
    ],
    "layer.freezing": false,
    "loss.asym": true,
    "loss.delta": 0.5,
    "loss.gamma": 0.3,
    "loss.weight": 0.5,
    "lr": "2e-05,2e-05",
    "lr.decay.factor": 0.5,
    "lr.decay.patience": 3,
    "lr.min": 1e-06,
    "lr.reset": true,
    "select.scenario": {
        "coronal": "equal.divide",
        "sagittal": "equal.divide",
        "transverse": "equal.divide"
    },
    "select.step": [
        {
            "coronal": "1",
            "sagittal": "1",
            "transverse": "1"
        },
        {
            "coronal": "2",
            "sagittal": "2",
            "transverse": "2"
        }
    ],
    "weight.annotated.slice": 2,
    "weight.annotation": 3,
    "weight.background": 0.2,
    "weight.distance.step": 5,
    "weight.prev.round.decay": 0.5
}