{
    "augment.low.limit": 2,
    "augment.methods": "elastic,rotate,flip.lr,flip.ud",
    "augment.times": 2,
    "augment.up.limit": 4,
    "batch.size": 8,
    "dropout": 0.3,
    "iter": 10,
    "layer.freezing": false,
    "loss.delta": 0.6,
    "loss.gamma": 0.5,
    "loss.weight": 0.5,
    "lr": [
        "2e-06,2e-06",
        "5e-06,5e-06",
        "1e-05,1e-05"
    ],
    "lr.decay.factor": 0.7,
    "lr.decay.patience": 3,
    "lr.min": 1e-06,
    "lr.reset": true,
    "select.scenario": "equal.divide",
    "select.step": "3,1,1"
}