{
    "augment.max": 3,
    "augment.methods": "elastic,rotate,flip.lr,flip.ud",
    "augment.min": 2,
    "augment.times": 4,
    "batch.size": 1,
    "dataset.ver": "au.1mm",
    "dropout": 0.3,
    "iter": 20,
    "layer.freezing": false,
    "loss.asym": true,
    "loss.delta": 0.5,
    "loss.gamma": 0.3,
    "loss.weight": 0.1,
    "lr": "8e-05,8e-05",
    "lr.decay.factor": 0.5,
    "lr.decay.patience": 3,
    "lr.min": 1e-06,
    "lr.reset": true,
    "select.scenario": "gravity.center",
    "select.step.coronal": "1",
    "select.step.sagittal": "1",
    "select.step.transverse": "1",
    "weight.background": 0.2,
    "weight.distance.step": 3,
    "weight.fp.fn": 4.0,
    "weight.prev.round.decay": 0.5,
    "weight.selected.slice": 1.0
}