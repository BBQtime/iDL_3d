{
    "augment.low.limit": 2,
    "augment.methods": "elastic,scale,translate,rotate,flip.lr,flip.ud",
    "augment.pct": 0.8,
    "augment.up.limit": 3,
    "batch.size": 8,
    "dropout": 0.3,
    "early.stop.patience": 30,
    "epochs": 500,
    "loss.delta": 0.6,
    "loss.gamma": 0.5,
    "loss.weight": 0.5,
    "lr": 0.0005,
    "lr.decay.factor": 0.5,
    "lr.decay.patience": 5,
    "lr.min": 1e-05
}