{
    "augment.low.limit": 2,
    "augment.method": "combine",
    "augment.pct": 0.8,
    "augment.up.limit": 3,
    "batch.size": 8,
    "cnn.name": "unet++",
    "dropout": 0.3,
    "early.stop.patience": 30,
    "epochs": [
        10,
        100
    ],
    "loss.bce.back.power": 2.0,
    "loss.bce.fore.weight": 0.5,
    "loss.hybrid.weight": 0.5,
    "loss.tversky.fore.power": 0.35,
    "loss.tversky.fore.weight": 0.5,
    "loss.tversky.fp.weight": 0.5,
    "lr": 7e-05,
    "lr.decay.factor": 0.5,
    "lr.decay.patience": 5,
    "lr.min": 1e-05
}