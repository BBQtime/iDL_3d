{
    "augment.max": 3,
    "augment.methods": "elastic,rotate,flip.lr,flip.ud",
    "augment.min": 2,
    "augment.pct": 0.8,
    "batch.size": 4,
    "cnn": "unet.slim",
    "cross.valid.fold": 4,
    "dropout": 0.3,
    "early.stop.epochs": 30,
    "epochs": 200,
    "keep.best.cnn.num": 5,
    "loss.asym": true,
    "loss.delta": 0.5,
    "loss.gamma": 0.3,
    "loss.weight": 1.0,
    "lr": 0.002,
    "lr.decay.factor": 0.5,
    "lr.decay.patience": 5,
    "lr.min": 1e-05
}